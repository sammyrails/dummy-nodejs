{
  "name": "products-crud-api",
  "version": "1.0.0",
  "description": "Products CRUD API backed by PostgreSQL",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --require tsconfig-paths/register src/index.ts",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
